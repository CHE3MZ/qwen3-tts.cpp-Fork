{
    "version": "release-1.0",
    "description": "C++17/GGML inference for Qwen3-TTS. CPU build — works on all Windows machines. For GPU acceleration use qwen-tts.cpp-vulkan or qwen-tts.cpp-cuda.",
    "homepage": "https://github.com/CHE3MZ/qwen3-tts.cpp-Fork",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/CHE3MZ/qwen3-tts.cpp-Fork/releases/download/release-1.0/qwen-tts-windows-x64-cpu.zip",
            "hash": "PLACEHOLDER_SHA256_CPU"
        }
    },
    "extract_dir": "qwen-tts-windows-x64-cpu",
    "bin": [
        ["qwen-tts.exe", "qwen-tts"]
    ],
    "shortcuts": [
        ["qwen-tts.exe", "qwen-tts"]
    ],
    "checkver": {
        "github": "https://github.com/CHE3MZ/qwen3-tts.cpp-Fork",
        "regex": "release-([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/CHE3MZ/qwen3-tts.cpp-Fork/releases/download/release-$version/qwen-tts-windows-x64-cpu.zip"
            }
        }
    },
    "notes": [
        "qwen-tts.cpp (CPU build) installed. Command: qwen-tts",
        "",
        "For GPU acceleration (faster generation):",
        "  Vulkan (AMD/Intel/NVIDIA): scoop install qwen-tts.cpp-vulkan",
        "  CUDA (NVIDIA only):        scoop install qwen-tts.cpp-cuda",
        "",
        "Download models:",
        "  See https://github.com/CHE3MZ/qwen3-tts.cpp-Fork#model-setup",
        "",
        "Quick start:",
        "  qwen-tts -m models -t \"Hello world\" -o hello.wav"
    ]
}
